{
  "name": "barbearia-saas-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test:appointments": "tsx --test src/modules/appointments/__tests__/appointments.rules.test.ts",
    "test:billing": "tsx --test src/modules/billing/__tests__/billing.logic.test.ts",
    "test:crm": "tsx --test src/modules/crm/__tests__/crm.calculations.test.ts",
    "test:dashboard": "tsx --test src/modules/dashboard/__tests__/dashboard.calculations.test.ts",
    "test:franchise": "tsx --test src/modules/franchise/__tests__/franchise.calculations.test.ts",
    "test:financial": "tsx --test src/modules/financial/__tests__/financial.calculations.test.ts",
    "test:notifications": "tsx --test src/modules/notifications/__tests__/notifications.schemas.test.ts",
    "test:automation": "tsx --test src/modules/automation/__tests__/automation.calculations.test.ts",
    "test:gamification": "tsx --test src/modules/gamification/__tests__/gamification.calculations.test.ts",
    "test:master": "tsx --test src/modules/master/__tests__/master.calculations.test.ts",
    "master:create-admin": "tsx src/scripts/create-master-admin.ts",
    "release:check": "tsx src/scripts/release-readiness.ts",
    "plans:seed": "tsx src/scripts/seed-commercial-plans.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "stripe": "^20.4.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
