NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barbearia_saas?schema=public"
JWT_ACCESS_SECRET="change-access-secret"
JWT_REFRESH_SECRET="change-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PRISMA_CLIENT_ENGINE_TYPE="library"
MASTER_JWT_SECRET="change-master-jwt-secret"
MASTER_JWT_EXPIRES_IN="8h"
CORS_ORIGIN="http://localhost:5173"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
MARKETING_EVENT_SALT="change-marketing-event-salt"
