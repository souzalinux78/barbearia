generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  OWNER
  ADMIN
  BARBER
  RECEPTION
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  EM_ATENDIMENTO
  FINALIZADO
  CANCELADO
  NO_SHOW
  BLOQUEADO
}

enum PaymentMethod {
  DINHEIRO
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  TRANSFERENCIA
}

enum PaymentStatus {
  PENDENTE
  PAGO
  CANCELADO
}

enum ExpenseType {
  FIXA
  VARIAVEL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

enum BillingGateway {
  STRIPE
  PIX
}

enum PlanName {
  FREE
  PRO
  PREMIUM
}

enum BillingPaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum LoyaltyProgramType {
  POINTS
  CASHBACK
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  EXPIRE
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

model Tenant {
  id                  String              @id @default(uuid()) @db.Uuid
  name                String
  slug                String              @unique
  email               String?
  phone               String?
  users               User[]
  roles               Role[]
  clients             Client[]
  services            Service[]
  appointments        Appointment[]
  appointmentServices AppointmentService[]
  payments            Payment[]
  commissions         Commission[]
  expenses            Expense[]
  products            Product[]
  inventoryLogs       InventoryMovement[]
  subscription        Subscription?
  billingHistory      BillingHistory[]
  gatewayConfig       PaymentGatewayConfig?
  billingLogs         BillingLog[]
  pushSubscriptions   PushSubscription[]
  loyaltyProgram      LoyaltyProgram?
  loyaltyTransactions LoyaltyTransaction[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@map("tenants")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      RoleName
  users     User[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, name])
  @@map("roles")
}

model User {
  id               String              @id @default(uuid()) @db.Uuid
  tenantId         String              @map("tenant_id") @db.Uuid
  roleId           String              @map("role_id") @db.Uuid
  name             String
  email            String
  phone            String?
  passwordHash     String              @map("password_hash")
  refreshTokenHash String?             @map("refresh_token_hash")
  active           Boolean             @default(true)
  commissionRate   Decimal             @default(40) @map("commission_rate") @db.Decimal(5, 2)
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role             Role                @relation(fields: [roleId], references: [id])
  appointments     Appointment[]       @relation("BarberAppointments")
  commissions      Commission[]
  inventoryLogs    InventoryMovement[]
  pushSubscriptions PushSubscription[]
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@unique([tenantId, email])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@index([tenantId])
  @@map("push_subscriptions")
}

model Client {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  name         String
  email        String?
  phone        String?
  birthDate    DateTime?     @map("birth_date")
  notes        String?
  vipBadge     Boolean       @default(false) @map("vip_badge")
  vip          Boolean       @default(false)
  noShowCount  Int           @default(0) @map("no_show_count")
  loyaltyPoints Decimal      @default(0) @map("loyalty_points") @db.Decimal(12, 2)
  cashbackBalance Decimal    @default(0) @map("cashback_balance") @db.Decimal(12, 2)
  totalSpent   Decimal       @default(0) @map("total_spent") @db.Decimal(12, 2)
  visitsCount  Int           @default(0) @map("visits_count")
  lastVisit    DateTime?     @map("last_visit")
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  payments     Payment[]
  loyaltyTransactions LoyaltyTransaction[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, vip])
  @@index([tenantId, lastVisit])
  @@map("clients")
}

model Service {
  id                  String              @id @default(uuid()) @db.Uuid
  tenantId            String              @map("tenant_id") @db.Uuid
  name                String
  description         String?
  durationMin         Int                 @map("duration_min")
  price               Decimal             @db.Decimal(10, 2)
  active              Boolean             @default(true)
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  appointmentServices AppointmentService[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("services")
}

model Appointment {
  id                  String               @id @default(uuid()) @db.Uuid
  tenantId            String               @map("tenant_id") @db.Uuid
  clientId            String?              @map("client_id") @db.Uuid
  barberId            String               @map("barber_id") @db.Uuid
  serviceId           String?              @map("service_id") @db.Uuid
  date                DateTime             @db.Date
  startTime           DateTime             @map("start_time") @db.Time(6)
  endTime             DateTime             @map("end_time") @db.Time(6)
  status              AppointmentStatus    @default(AGENDADO)
  price               Decimal              @default(0) @db.Decimal(10, 2)
  notes               String?
  reminderSent        Boolean              @default(false) @map("reminder_sent")
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client              Client?              @relation(fields: [clientId], references: [id])
  barber              User                 @relation("BarberAppointments", fields: [barberId], references: [id])
  service             Service?             @relation(fields: [serviceId], references: [id])
  appointmentServices AppointmentService[]
  payments            Payment[]
  commission          Commission[]
  loyaltyTransactions LoyaltyTransaction[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([date])
  @@index([barberId])
  @@index([tenantId, date, barberId])
  @@index([tenantId, status, date])
  @@map("appointments")
}

model LoyaltyProgram {
  id                 String             @id @default(uuid()) @db.Uuid
  tenantId           String             @unique @map("tenant_id") @db.Uuid
  active             Boolean            @default(false)
  type               LoyaltyProgramType
  pointsPerReal      Decimal            @default(1) @map("points_per_real") @db.Decimal(10, 2)
  cashbackPercentage Decimal            @default(0) @map("cashback_percentage") @db.Decimal(5, 2)
  expirationDays     Int                @default(90) @map("expiration_days")
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@index([active, type])
  @@map("loyalty_programs")
}

model LoyaltyTransaction {
  id            String                 @id @default(uuid()) @db.Uuid
  tenantId      String                 @map("tenant_id") @db.Uuid
  clientId      String                 @map("client_id") @db.Uuid
  appointmentId String?                @map("appointment_id") @db.Uuid
  type          LoyaltyTransactionType
  amount        Decimal                @db.Decimal(12, 2)
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment   Appointment?           @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime               @default(now()) @map("created_at")

  @@index([tenantId, clientId, createdAt])
  @@index([tenantId, type, createdAt])
  @@index([appointmentId])
  @@map("loyalty_transactions")
}

model AppointmentService {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  appointmentId String      @map("appointment_id") @db.Uuid
  serviceId     String      @map("service_id") @db.Uuid
  durationMin   Int         @map("duration_min")
  price         Decimal     @db.Decimal(10, 2)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@unique([appointmentId, serviceId])
  @@index([tenantId])
  @@index([tenantId, serviceId])
  @@map("appointment_services")
}

model Payment {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  appointmentId String?      @map("appointment_id") @db.Uuid
  clientId      String?      @map("client_id") @db.Uuid
  method        PaymentMethod
  status        PaymentStatus @default(PAGO)
  amount        Decimal      @db.Decimal(10, 2)
  paidAt        DateTime     @default(now()) @map("paid_at")
  notes         String?
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  client        Client?      @relation(fields: [clientId], references: [id])
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, paidAt])
  @@index([tenantId, status, paidAt])
  @@index([status])
  @@map("payments")
}

model Commission {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  barberId      String       @map("barber_id") @db.Uuid
  appointmentId String?      @map("appointment_id") @db.Uuid
  percentage    Decimal      @db.Decimal(5, 2)
  amount        Decimal      @db.Decimal(10, 2)
  paid          Boolean      @default(false)
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  barber        User         @relation(fields: [barberId], references: [id])
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, barberId])
  @@index([tenantId, createdAt])
  @@map("commissions")
}

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  description String
  category    String
  type        ExpenseType
  amount      Decimal  @db.Decimal(10, 2)
  dueDate     DateTime @map("due_date") @db.Date
  paid        Boolean  @default(false)
  paidAt      DateTime? @map("paid_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, paidAt])
  @@index([tenantId, dueDate])
  @@map("expenses")
}

model Product {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  name           String
  sku            String?
  price          Decimal             @db.Decimal(10, 2)
  cost           Decimal?            @db.Decimal(10, 2)
  stockQuantity  Int                 @default(0) @map("stock_quantity")
  minStock       Int                 @default(0) @map("min_stock")
  active         Boolean             @default(true)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryMoves InventoryMovement[]
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

model InventoryMovement {
  id            String                @id @default(uuid()) @db.Uuid
  tenantId      String                @map("tenant_id") @db.Uuid
  productId     String                @map("product_id") @db.Uuid
  performedById String?               @map("performed_by_id") @db.Uuid
  type          InventoryMovementType
  quantity      Int
  reason        String?
  unitCost      Decimal?              @map("unit_cost") @db.Decimal(10, 2)
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id])
  performedBy   User?                 @relation(fields: [performedById], references: [id])
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@index([tenantId, createdAt])
  @@map("inventory_movements")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  tenantId               String             @unique @map("tenant_id") @db.Uuid
  planId                 String             @map("plan_id") @db.Uuid
  pendingPlanId          String?            @map("pending_plan_id") @db.Uuid
  gateway                BillingGateway
  externalSubscriptionId String?            @map("external_subscription_id")
  status                 SubscriptionStatus @default(TRIALING)
  currentPeriodStart     DateTime           @map("current_period_start")
  currentPeriodEnd       DateTime           @map("current_period_end")
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  tenant                 Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                   Plan               @relation(fields: [planId], references: [id])
  pendingPlan            Plan?              @relation("PendingPlan", fields: [pendingPlanId], references: [id])
  billingHistory         BillingHistory[]
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  @@index([planId])
  @@index([pendingPlanId])
  @@index([status])

  @@map("subscriptions")
}

model Plan {
  id                   String         @id @default(uuid()) @db.Uuid
  name                 PlanName       @unique
  price                Decimal        @db.Decimal(10, 2)
  maxUsers             Int            @map("max_users")
  maxBarbers           Int            @map("max_barbers")
  maxAppointmentsMonth Int            @map("max_appointments_month")
  features             Json
  subscriptions        Subscription[]
  pendingSubscriptions Subscription[] @relation("PendingPlan")
  createdAt            DateTime       @default(now()) @map("created_at")

  @@map("plans")
}

model BillingHistory {
  id             String               @id @default(uuid()) @db.Uuid
  tenantId       String               @map("tenant_id") @db.Uuid
  subscriptionId String               @map("subscription_id") @db.Uuid
  amount         Decimal              @db.Decimal(10, 2)
  status         BillingPaymentStatus
  gateway        BillingGateway
  paidAt         DateTime?            @map("paid_at")
  externalRef    String?              @map("external_ref")
  metadata       Json?
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription   Subscription         @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([subscriptionId])
  @@index([status])
  @@map("billing_history")
}

model PaymentGatewayConfig {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String?   @unique @map("tenant_id") @db.Uuid
  stripeActive        Boolean   @default(false) @map("stripe_active")
  pixActive           Boolean   @default(false) @map("pix_active")
  stripeSecretKey     String?   @map("stripe_secret_key")
  stripeWebhookSecret String?   @map("stripe_webhook_secret")
  pixApiKey           String?   @map("pix_api_key")
  pixWebhookSecret    String?   @map("pix_webhook_secret")
  tenant              Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([stripeActive, pixActive])
  @@map("payment_gateway_configs")
}

model BillingLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  level     String
  event     String
  payload   Json?
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("billing_logs")
}
